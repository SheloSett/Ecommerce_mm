# Base de datos
DB_USER=ecommerce_user
DB_PASSWORD=ecommerce_pass
DB_NAME=ecommerce_db

# JWT (cambia esto por una clave segura)
JWT_SECRET=tu_clave_secreta_muy_larga_y_segura_aqui

# MercadoPago (obtén tu token en https://www.mercadopago.com.ar/developers)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx

# URLs
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:4000

# Email (opcional) - notificaciones al admin para solicitudes de cuenta mayorista
# Si no se configura, las solicitudes igualmente aparecen en el panel de admin
ADMIN_EMAIL=tu_email@gmail.com
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion_gmail
# SMTP_HOST=smtp.gmail.com   # Por defecto: smtp.gmail.com
# SMTP_PORT=587              # Por defecto: 587
