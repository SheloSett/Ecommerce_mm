# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN PRODUCCIÓN — VPS Hostinger
# Copiar a backend/.env en el VPS y completar con los valores reales.
# IMPORTANTE: este archivo es solo plantilla, NO subir el .env real al repo.
# ──────────────────────────────────────────────────────────────────────────────

# ──── Base de datos local (Postgres en el mismo VPS) ──────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# Como Postgres corre en el mismo servidor, usamos localhost:5432
DATABASE_URL="postgresql://ecommerce_user:CAMBIAR_PASSWORD_FUERTE@localhost:5432/ecommerce_db?schema=public"

# ──── JWT ─────────────────────────────────────────────────────────────────────
# Generar uno seguro de 64+ caracteres con: openssl rand -hex 64
JWT_SECRET=CAMBIAR_POR_UNA_CLAVE_LARGA_Y_ALEATORIA_DE_64_CHARS_MINIMO

# ──── MercadoPago ─────────────────────────────────────────────────────────────
# Token de PRODUCCIÓN (no el TEST). Obtenelo en https://mercadopago.com.ar/developers
MP_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXX

# ──── URLs públicas ───────────────────────────────────────────────────────────
# FRONTEND_URL: usado por el backend para construir back_urls de MercadoPago
# BACKEND_URL: usado por MP para enviar webhooks (notification_url)
FRONTEND_URL=https://igwtstore.com.ar
BACKEND_URL=https://igwtstore.com.ar

# ──── Email (SMTP — Gmail con contraseña de aplicación) ───────────────────────
# Importante: usar 'Contraseña de aplicación' de Gmail, NO la contraseña normal.
# Generala en https://myaccount.google.com/apppasswords (requiere 2FA activado).
# La clave va SIN espacios (Gmail la muestra con espacios cada 4 chars, ignoralos).
ADMIN_EMAIL=tuemail@gmail.com
SMTP_USER=tuemail@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
# SMTP_HOST=smtp.gmail.com   # Default si no se setea
# SMTP_PORT=587              # Default si no se setea (STARTTLS). Para SSL puro usar 465.

# ──── Cloudinary (imágenes de productos/slides/variantes) ─────────────────────
# Las imágenes que ya están subidas a Cloudinary seguirán sirviéndose desde ahí.
# No hace falta migrarlas — Cloudinary es CDN externo, va a funcionar igual.
CLOUDINARY_CLOUD_NAME=dqdxuqhvl
CLOUDINARY_API_KEY=XXXXXXXXXXXXX
CLOUDINARY_API_SECRET=XXXXXXXXXXXXX

# ──── IA: Google Gemini (autocompletar producto desde la foto + generar fotos) ─
# Una sola key cubre texto/visión Y generación de imágenes.
# Obtené una gratis en https://aistudio.google.com → "Get API key" (tiene nivel gratuito).
# Si esta variable falta, los botones de IA quedan deshabilitados (el resto del sitio anda igual).
# Claude (Anthropic): proveedor PRIMARIO del texto (título/descripción/SKU desde la foto).
# Si está seteada, se usa Claude; si falla o falta, cae a Gemini. Requiere cuenta con facturación
# en https://console.anthropic.com. Claude no genera imágenes (eso sigue con Gemini/OpenAI).
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-8   # opcional, override del modelo
GEMINI_API_KEY=
# Opcionales — solo si Google renombra los modelos (defaults ya están en el código):
# GEMINI_TEXT_MODEL=gemini-3.5-flash
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
# Respaldo de generación de imágenes (OpenAI). Si Gemini falla/sin cuota, se usa este.
# Necesita cuenta con facturación en https://platform.openai.com. Opcional.
OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1

# ──── Puerto interno del backend (no exponer al exterior, nginx hace proxy) ───
PORT=4000

# ──── Modo Node ───────────────────────────────────────────────────────────────
NODE_ENV=production
