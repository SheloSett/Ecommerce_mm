generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())

  @@map("users")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  slug      String     @unique
  // Relación self-referencial para subcategorías: una categoría puede tener padre y/o hijos
  parentId  Int?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  products  Product[]  // M2M implícita — inverso de Product.categories
  createdAt DateTime   @default(now())

  @@map("categories")
}

model Product {
  id              Int         @id @default(autoincrement())
  name            String
  description     String?
  price           Float
  cost                 Float?  // Precio de costo (interno, solo visible para el admin)
  ivaRate              Float   @default(21) // Alícuota de IVA aplicable: 10.5 o 21 (%)
  salePrice            Float?  // Precio oferta minorista (debe ser < price)
  wholesalePrice       Float?  // Precio mayorista para clientes tipo MAYORISTA
  wholesaleSalePrice   Float?  // Precio oferta mayorista (debe ser < wholesalePrice)
  minQuantity     Int         @default(1) // Cantidad mínima para compra mayorista
  stock           Int         @default(0)
  stockUnlimited  Boolean     @default(false) // Si true, el stock es ilimitado (∞)
  stockBreak      Int?        // Umbral de quiebre de stock: si stock <= stockBreak, aparece en la pestaña de alertas
  // Descuentos por cantidad minorista: [{ minQty: number, price: number }] ordenado por minQty asc.
  // Se aplica el tier con mayor minQty que no supere la cantidad pedida.
  priceTiers           Json?
  // Descuentos por cantidad mayorista: misma estructura, aplica solo a clientes MAYORISTA.
  wholesalePriceTiers  Json?
  sku             String?     // Código SKU del producto
  youtubeUrl      String?     // URL de video de YouTube del producto
  weight          Float?      // Peso en kg
  length          Float?      // Largo en cm
  width           Float?      // Ancho en cm
  height          Float?      // Alto en cm
  images          String[]
  // categoryId/category reemplazados por relación M2M — un producto puede tener varias categorías
  // categoryId   Int?
  // category     Category?   @relation(fields: [categoryId], references: [id])
  categories      Category[]  // M2M implícita — Prisma genera la tabla _CategoryToProduct
  orderItems      OrderItem[]
  cartItems       CartItem[]  // Items de carrito que referencian este producto
  wishlistItems   Wishlist[]  // Registros de favoritos que incluyen este producto
  visibility      CustomerVisibility @default(AMBOS) // Quién puede ver este producto: AMBOS, MAYORISTA o MINORISTA
  active          Boolean     @default(true)
  featured        Boolean     @default(false)
  hotSeller          Boolean  @default(false) // Más vendidos — se activa manual o automático por threshold
  hotSellerThreshold Int?                    // Si se define, hotSeller se auto-activa cuando totalSold >= este valor
  attributes      ProductAttribute[]  // Atributos de variante definidos para este producto
  variants        ProductVariant[]    // Combinaciones generadas
  // onSale: aparece en la sección "Ofertas" de la home (separado de destacados)
  onSale          Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("products")
}

enum CustomerVisibility {
  AMBOS
  MAYORISTA
  MINORISTA
}

model Order {
  id             Int           @id @default(autoincrement())
  customerName   String
  customerEmail  String        // Email de contacto (para enviar confirmaciones/facturas)
  customerPhone  String?
  // customerId vincula la orden a la cuenta del cliente registrado.
  // Es opcional para soportar compras de invitados (sin cuenta).
  customerId     Int?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status         OrderStatus   @default(PENDING)
  paymentMethod  PaymentMethod @default(MERCADOPAGO)
  total          Float
  mpPaymentId    String?
  mpStatus       String?
  mpPreferenceId String?
  items          OrderItem[]
  notifications  Notification[]
  // Cupón aplicado a esta orden
  couponId       Int?
  coupon         Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponDiscount Float?        // Monto descontado por el cupón (en ARS)
  couponUsage    CouponUsage?
  // Campos exclusivos para cotizaciones:
  // clientSnapshot: copia de los items visible al cliente. Se actualiza solo cuando el admin presiona
  //   "Actualizar cotización". Mientras no se actualice, el cliente sigue viendo la versión anterior.
  clientSnapshot Json?
  // adminNotes: mensaje del admin al cliente cuando publica cambios o aprueba la cotización.
  adminNotes     String?
  // customerNote: comentario libre que el cliente deja al momento de hacer el pedido/cotización.
  customerNote   String?
  // cancelReason: motivo de cancelación ingresado por el cliente.
  cancelReason   String?
  // salesChannel: de dónde llegó el cliente. "WEB" para órdenes online, valores personalizados para ventas manuales.
  // Default "WEB" para que todos los pedidos existentes queden correctamente clasificados.
  salesChannel   String        @default("WEB")
  // customerType: si el cliente fue atendido como MINORISTA o MAYORISTA. Default MINORISTA para pedidos web.
  customerType   String        @default("MINORISTA")
  // wantsInvoice: el cliente mayorista solicitó factura (se aplica 21% IVA al total)
  wantsInvoice        Boolean       @default(false)
  // ivaAmount: monto del IVA aplicado (0 si no solicitó factura)
  ivaAmount           Float         @default(0)
  // fulfillmentStatus: etapa logística del pedido (independiente del estado de pago)
  fulfillmentStatus   String        @default("PENDIENTE")  // PENDIENTE | EN_PREPARACION | ENVIADO | ENTREGADO
  // shippingMethod: cómo el cliente quiere recibir su pedido. "RETIRO" = retiro en local, "ENVIO" = acordar envío.
  // Extensible en el futuro para soportar correo argentino u otros carriers.
  shippingMethod      String        @default("RETIRO")     // RETIRO | ENVIO
  returnRequests  ReturnRequest[]    // Solicitudes de arrepentimiento vinculadas a esta orden
  seenByAdmin     Boolean       @default(false) // true = el admin abrió el detalle de la cotización
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("orders")
}

// Notificaciones push para clientes: se crean cuando el admin actualiza o aprueba una cotización.
model Notification {
  id         Int              @id @default(autoincrement())
  customerId Int
  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId    Int?
  order      Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type       NotificationType
  message    String
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@map("notifications")
}

model OrderItem {
  id           Int     @id @default(autoincrement())
  orderId      Int
  productId    Int
  quantity     Int
  price        Float
  variantId    Int?    // ID de la variante seleccionada (null si sin variante)
  variantLabel String? // Ej: "Color: Negro / RGB: Si" — guardado al momento del pedido
  variantSku   String? // SKU de la variante seleccionada al momento del pedido
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum Role {
  ADMIN
  USER
}

enum OrderStatus {
  PENDING        // Esperando revisión del admin
  QUOTE_APPROVED // Admin aprobó la cotización — cliente debe pagar
  APPROVED       // Pago confirmado
  REJECTED
  CANCELLED
}

enum NotificationType {
  COTIZACION_ACTUALIZADA        // Admin publicó cambios en items
  COTIZACION_APROBADA           // Admin aprobó la cotización
  COTIZACION_RECHAZADA          // Admin rechazó la cotización
  COTIZACION_CANCELADA_CLIENTE  // Cliente canceló (notifica al admin via email, no via este modelo)
}

enum PaymentMethod {
  MERCADOPAGO
  EFECTIVO
  TRANSFERENCIA
  COTIZACION
}

model Customer {
  id                Int                @id @default(autoincrement())
  name              String
  email             String             @unique
  password          String?            // Hasheada con bcrypt; opcional para no romper registros anteriores
  phone             String?
  documentType      String?            // Tipo de documento: "DNI", "CUIT" o "CUIL" (null = registros anteriores)
  cuit              String?            // Número de documento (DNI / CUIT / CUIL según documentType)
  status            CustomerStatus     @default(PENDING)
  type              CustomerType       @default(MINORISTA)
  notes             String?            // Notas internas del admin
  mayoristaRequests   MayoristaRequest[]   // Solicitudes para pasar a cuenta mayorista
  emailChangeRequests EmailChangeRequest[] // Solicitudes de cambio de email pendientes de aprobación
  wishlist          Wishlist[]         // Productos guardados como favoritos
  cart              Cart?              // Carrito activo del cliente (uno por cliente)
  orders            Order[]            // Órdenes vinculadas a esta cuenta
  notifications     Notification[]     // Notificaciones de cotizaciones
  coupons           Coupon[]           // Cupones personales asignados a este cliente
  returnRequests    ReturnRequest[]    // Solicitudes de arrepentimiento del cliente
  seenByAdmin       Boolean            @default(false) // true = el admin abrió el detalle del cliente
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("customers")
}

// Carrito persistido en BD para que el admin pueda ver carritos activos
model Cart {
  id         Int        @id @default(autoincrement())
  customerId Int        @unique
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]
  updatedAt  DateTime   @updatedAt
  createdAt  DateTime   @default(now())

  @@map("carts")
}

// Items del carrito: guarda nombre y precio al momento de agregar
model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId Int      // Referencia al producto (con FK para poder hacer include de stock)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade) // onDelete: Cascade: si se elimina el producto, se elimina el item del carrito
  name         String   // Nombre del producto al momento de agregar
  price        Float    // Precio efectivo según tipo de cliente
  quantity     Int
  image        String?  // Primera imagen del producto
  variantId    Int?     // ID de la variante seleccionada (null si el producto no tiene variantes)
  variantLabel String?  // Etiqueta legible: "Rojo / 2m" (para mostrar en carrito y checkout)

  @@map("cart_items")
}

model MayoristaRequest {
  id         Int                    @id @default(autoincrement())
  customerId Int
  customer   Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  message    String?                // Mensaje opcional del cliente explicando el motivo
  status     MayoristaRequestStatus @default(PENDING)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@map("mayorista_requests")
}

enum CustomerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CustomerType {
  MAYORISTA
  MINORISTA
}

enum MayoristaRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Cupones de descuento: generales (customerId null) o personales (customerId asignado)
model Coupon {
  id                 Int          @id @default(autoincrement())
  code               String       @unique
  description        String?
  discountType       DiscountType @default(PERCENTAGE)
  discountValue      Float        // Porcentaje (0-100) o monto fijo en ARS
  minPurchase        Float?       // Compra mínima para activar el cupón (null = sin mínimo)
  maxUses            Int?         // Usos totales máximos (null = ilimitado)
  maxUsesPerCustomer Int?         // Usos máximos por cliente/email (null = ilimitado)
  expiresAt          DateTime?    // Fecha de vencimiento (null = sin vencimiento)
  customerId         Int?         // null = para todos; asignado = cupón personal
  customer           Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  active             Boolean      @default(true)
  usages             CouponUsage[]
  orders             Order[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("coupons")
}

// Registro de cada uso de un cupón (uno por orden)
model CouponUsage {
  id            Int      @id @default(autoincrement())
  couponId      Int
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orderId       Int      @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerEmail String   // email del comprador al momento del uso
  usedAt        DateTime @default(now())

  @@map("coupon_usages")
}

enum DiscountType {
  PERCENTAGE // % del total
  FIXED      // monto fijo en ARS
}

// Slides del carrusel del hero en la página de inicio
model Slide {
  id        Int      @id @default(autoincrement())
  image     String   // nombre del archivo en /uploads
  title     String?  // título opcional superpuesto sobre la imagen
  subtitle  String?  // subtítulo opcional
  url       String?  // URL de destino al hacer click en el slide (puede ser relativa o absoluta)
  order     Int      @default(0) // posición en el carrusel (menor = primero)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("slides")
}

model Gasto {
  id          Int        @id @default(autoincrement())
  amount      Float
  description String
  type        GastoType
  // subtype: "GASTO" (gasto normal) o "RMA" (devolución/reparación de producto)
  subtype     String     @default("GASTO")
  // productId: referencia al producto devuelto (solo cuando subtype = "RMA")
  productId   Int?
  date        DateTime   @default(now())
  createdAt   DateTime   @default(now())

  @@map("gastos")
}

enum GastoType {
  PERSONAL
  NEGOCIO
}

// Registro de compras de stock al proveedor
model Purchase {
  id        Int            @id @default(autoincrement())
  supplier  String         // Nombre del proveedor
  date      DateTime       // Fecha de la compra
  items     PurchaseItem[]
  createdAt DateTime       @default(now())

  @@map("purchases")
}

// Cada línea de una compra (un producto comprado)
model PurchaseItem {
  id          Int      @id @default(autoincrement())
  purchaseId  Int
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  sku         String?  // SKU del producto (puede no tenerlo)
  productName String   // Nombre del producto en el momento de la compra
  cost        Float    // Costo unitario pagado
  quantity    Int      // Unidades recibidas
  productId   Int?     // ID del producto afectado (creado o actualizado)

  @@map("purchase_items")
}

// Solicitudes de cambio de email enviadas por clientes al admin para su aprobación
model EmailChangeRequest {
  id          Int                      @id @default(autoincrement())
  customerId  Int
  customer    Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  newEmail    String                   // Email solicitado
  reason      String                   // Motivo del cambio
  status      EmailChangeRequestStatus @default(PENDING)
  adminNotes  String?                  // Respuesta del admin al rechazar
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@map("email_change_requests")
}

enum EmailChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Solicitudes de arrepentimiento / devolución (Ley 24.240 — 10 días hábiles)
model ReturnRequest {
  id            Int                 @id @default(autoincrement())
  // orderId opcional: el cliente puede indicar el número de pedido en el mensaje
  orderId       Int?
  order         Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customerId    Int?
  customer      Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String
  customerEmail String
  customerPhone String?             // Teléfono de contacto ingresado en el formulario
  reason        String              // Mensaje / motivo del cliente
  status        ReturnRequestStatus @default(PENDING)
  adminNotes    String?             // Instrucciones de envío (si APPROVED) o motivo de rechazo
  seenByAdmin   Boolean             @default(false) // true = el admin abrió el detalle
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("return_requests")
}

enum ReturnRequestStatus {
  PENDING   // Pendiente de revisión del admin
  APPROVED  // Aprobado — se envían instrucciones de devolución al cliente
  REJECTED  // Rechazado con motivo
}

// Favoritos del cliente: cada fila = un producto guardado por un cliente
model Wishlist {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@map("wishlists")
}

// Configuración general del sitio (key-value): tema, modo mantenimiento, etc.
model SiteConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("site_config")
}

// Atributo de un producto: nombre libre definido por el admin (ej: "Color", "Metros", "Voltaje")
// Cada producto define sus propios atributos independientemente.
model ProductAttribute {
  id        Int                    @id @default(autoincrement())
  productId Int
  product   Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String                 // Nombre libre: "Color", "Tamaño", "Material"
  position  Int                    @default(0)
  values    ProductAttributeValue[]
  createdAt DateTime               @default(now())

  @@map("product_attributes")
}

// Valor posible de un atributo (ej: "Rojo", "1 metro", "220V")
model ProductAttributeValue {
  id          Int              @id @default(autoincrement())
  attributeId Int
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  position    Int              @default(0)
  createdAt   DateTime         @default(now())

  @@unique([attributeId, value])
  @@map("product_attribute_values")
}

// Combinación específica de atributos para un producto (una variante)
// combination: JSON con los pares nombre-valor, ej: [{ "name": "Color", "value": "Rojo" }, { "name": "Metros", "value": "2m" }]
model ProductVariant {
  id             Int      @id @default(autoincrement())
  productId      Int
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  combination    Json     // [{ name, value }] — snapshot de los atributos al generar
  sku            String?
  stock          Int      @default(0)
  stockUnlimited Boolean  @default(false)
  price          Float?   // null = usar precio base del producto
  cost           Float?   // costo de la variante (sobrescribe el costo del producto padre)
  image          String?  // imagen específica de esta variante (nombre de archivo en /uploads)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("product_variants")
}
